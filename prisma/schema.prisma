generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum BillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum PaymentProvider {
  STRIPE
  MERCADO_PAGO
  MANUAL
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
  CANCELED
}

enum CreditReason {
  PLAN_RENEWAL
  PURCHASE
  GENERATION
  REFUND
  ADMIN_ADJUSTMENT
  EXPIRED
}

enum AssetType {
  CLOTHING_REFERENCE
  BRAND_LOGO
  GENERATED_IMAGE
  STYLE_REFERENCE
  OTHER
}

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum ImageProvider {
  OPENAI
  GEMINI
  STABILITY
  OTHER
}

enum PromptTemplateCategory {
  FASHION
  RESTAURANT
  BEAUTY
  BARBERSHOP
  FITNESS
  GENERAL
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  BILLING
  GENERATION
  SYSTEM
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  passwordHash String?
  role         UserRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  memberships     Membership[]
  invitationsSent Invitation[] @relation("InvitationSender")

  createdGenerations Generation[]   @relation("GenerationCreatedBy")
  uploadedAssets     Asset[]        @relation("AssetUploadedBy")
  auditLogs          AuditLog[]     @relation("AuditActor")
  createdApiKeys     ApiKey[]       @relation("ApiKeyCreatedBy")
  notifications      Notification[]

  @@index([email])
}

model Account {
  id     String @id @default(cuid())
  userId String

  type              String
  provider          String
  providerAccountId String

  refresh_token String? @db.Text
  access_token  String? @db.Text
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String? @db.Text
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id     String             @id @default(cuid())
  name   String
  slug   String             @unique
  status OrganizationStatus @default(ACTIVE)

  document String?
  phone    String?
  website  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships     Membership[]
  invitations     Invitation[]
  subscriptions   Subscription[]
  invoices        Invoice[]
  payments        Payment[]
  creditLedger    CreditLedger[]
  assets          Asset[]
  generations     Generation[]
  promptTemplates PromptTemplate[]
  brandProfile    BrandProfile?
  apiKeys         ApiKey[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  webhookEvents   WebhookEvent[]

  @@index([slug])
  @@index([status])
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Invitation {
  id             String @id @default(cuid())
  organizationId String

  email String
  role  MembershipRole @default(MEMBER)
  token String         @unique

  expiresAt  DateTime
  acceptedAt DateTime?

  invitedById String?
  createdAt   DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([email])
  @@index([token])
}

model Plan {
  id   String @id @default(cuid())
  name String
  slug String @unique

  monthlyPriceCents Int
  monthlyCredits    Int

  maxMembers   Int?
  maxStorageMb Int?
  active       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@index([active])
  @@index([slug])
}

model Subscription {
  id             String  @id @default(cuid())
  organizationId String
  planId         String?

  status BillingStatus @default(TRIALING)

  provider               PaymentProvider?
  providerCustomerId     String?
  providerSubscriptionId String?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?

  planNameSnapshot       String
  planPriceCentsSnapshot Int
  planCreditsSnapshot    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan?        @relation(fields: [planId], references: [id], onDelete: SetNull)

  invoices Invoice[]
  payments Payment[]

  @@index([organizationId])
  @@index([planId])
  @@index([status])
  @@index([providerCustomerId])
  @@index([providerSubscriptionId])
}

model Invoice {
  id             String  @id @default(cuid())
  organizationId String
  subscriptionId String?

  provider          PaymentProvider?
  providerInvoiceId String?

  number String?       @unique
  status InvoiceStatus @default(OPEN)

  currency        String @default("BRL")
  subtotalCents   Int
  discountCents   Int    @default(0)
  taxCents        Int    @default(0)
  totalCents      Int
  amountPaidCents Int    @default(0)

  dueDate    DateTime?
  paidAt     DateTime?
  canceledAt DateTime?

  hostedUrl String?
  pdfUrl    String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  payments Payment[]

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([status])
  @@index([providerInvoiceId])
  @@index([createdAt])
}

model Payment {
  id             String  @id @default(cuid())
  organizationId String
  subscriptionId String?
  invoiceId      String?

  provider          PaymentProvider @default(MANUAL)
  providerPaymentId String?

  status PaymentStatus @default(PENDING)

  currency    String @default("BRL")
  amountCents Int

  paidAt     DateTime?
  refundedAt DateTime?
  canceledAt DateTime?

  failureReason String?
  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@unique([provider, providerPaymentId])
  @@index([organizationId])
  @@index([subscriptionId])
  @@index([invoiceId])
  @@index([status])
  @@index([provider])
}

model WebhookEvent {
  id             String  @id @default(cuid())
  organizationId String?

  provider  PaymentProvider
  eventId   String
  eventType String

  status WebhookStatus @default(RECEIVED)

  payload      Json
  errorMessage String? @db.Text

  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([provider, eventId])
  @@index([organizationId])
  @@index([provider])
  @@index([eventType])
  @@index([status])
  @@index([receivedAt])
}

model CreditLedger {
  id             String @id @default(cuid())
  organizationId String

  amount Int
  reason CreditReason

  referenceType String?
  referenceId   String?
  description   String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([reason])
  @@index([referenceType, referenceId])
  @@index([createdAt])
}

model BrandProfile {
  id             String @id @default(cuid())
  organizationId String @unique

  businessName   String
  niche          String?
  targetAudience String?
  toneOfVoice    String?

  primaryColor   String?
  secondaryColor String?
  instagram      String?
  defaultStyle   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Asset {
  id             String  @id @default(cuid())
  organizationId String
  uploadedById   String?

  type AssetType

  fileName  String?
  mimeType  String?
  sizeBytes Int?
  width     Int?
  height    Int?

  storageKey String
  publicUrl  String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User?        @relation("AssetUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  outputOfGeneration Generation?            @relation("GenerationOutputAsset")
  generationInputs   GenerationInputAsset[]

  @@index([organizationId])
  @@index([uploadedById])
  @@index([type])
  @@index([createdAt])
}

model PromptTemplate {
  id             String  @id @default(cuid())
  organizationId String?

  name        String
  category    PromptTemplateCategory @default(FASHION)
  description String?
  template    String                 @db.Text

  isSystem Boolean @default(false)
  active   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generations  Generation[]

  @@index([organizationId])
  @@index([category])
  @@index([active])
}

model Generation {
  id             String  @id @default(cuid())
  organizationId String
  createdById    String?

  promptTemplateId String?

  status   GenerationStatus @default(PENDING)
  provider ImageProvider?
  model    String?

  inputData Json

  prompt         String  @db.Text
  negativePrompt String? @db.Text

  outputAssetId String? @unique

  creditsUsed     Int      @default(1)
  costCents       Int?
  providerCostUsd Decimal? @db.Decimal(10, 6)

  errorMessage String? @db.Text

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?           @relation("GenerationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  promptTemplate PromptTemplate? @relation(fields: [promptTemplateId], references: [id], onDelete: SetNull)
  outputAsset    Asset?          @relation("GenerationOutputAsset", fields: [outputAssetId], references: [id], onDelete: SetNull)

  inputAssets GenerationInputAsset[]

  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([provider])
  @@index([createdAt])
}

model GenerationInputAsset {
  generationId String
  assetId      String

  generation Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  asset      Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([generationId, assetId])
  @@index([assetId])
}

model ApiKey {
  id             String  @id @default(cuid())
  organizationId String
  createdById    String?

  name String

  // Nunca salvar a chave pura.
  // Salvar apenas hash + prefixo visivel.
  keyHash   String @unique
  keyPrefix String

  scopes     String[]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("ApiKeyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([createdById])
  @@index([keyPrefix])
  @@index([revokedAt])
}

model Notification {
  id             String  @id @default(cuid())
  organizationId String
  userId         String?

  type    NotificationType @default(INFO)
  title   String
  message String           @db.Text

  actionUrl String?
  readAt    DateTime?

  metadata Json?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
}

model AuditLog {
  id             String  @id @default(cuid())
  organizationId String?
  actorId        String?

  action   String
  entity   String?
  entityId String?

  ipAddress String?
  userAgent String?

  metadata Json?

  createdAt DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([actorId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}
